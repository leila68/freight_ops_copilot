# NOTE: now that the backend runs inside Docker (see docker-compose.yml),
# these values are NOT used directly — docker-compose.yml sets the real
# environment variables for the backend container (POSTGRES_HOST=db,
# POSTGRES_PORT=5432, the internal Docker network values).
# This file is kept only as a reference / fallback for pydantic-settings
# defaults if the app is ever run outside Docker again.
POSTGRES_USER=freight_user
POSTGRES_PASSWORD=freight_pass
POSTGRES_DB=freight_ops
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
 
JWT_SECRET_KEY=dev-secret-change-this-later
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
 
 
 